{
    "name": "elmekadem/architector-admin",
    "description": "A powerful Laravel admin dashboard generator with automatic Tailwind UI scaffolding, API-driven CRUD operations, and dynamic entity management",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Adam Elmekadem",
            "email": "adam@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Elmekadem\\ArchitectorAdmin\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Elmekadem\\ArchitectorAdmin\\Providers\\ArchitectorServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
